{$DOMAIN} {
  encode gzip

  @api path /api/* /health
  reverse_proxy @api controller:3000

  @srsapi path /rtc/* /api/* /console/*
  reverse_proxy @srsapi srs:1985 {
    header_up Host {host}
  }

  @srshttp path /live/* /players/* /libs/*
  reverse_proxy @srshttp srs:8080

  header {
    Access-Control-Allow-Origin *
    Access-Control-Allow-Methods "GET, POST, OPTIONS, DELETE"
    Access-Control-Allow-Headers "Content-Type, Authorization, X-Relay-Secret"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  respond / "HMG ClassDeck No-OBS Social Relay is running" 200
}
